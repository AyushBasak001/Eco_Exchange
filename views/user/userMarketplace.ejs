<%- include('../partials/htmlHead.ejs', {pageCss: "/styles/user/userMarketplace.css"}) %>  

<body>
    <div class="top-bar">
        <%- include('../partials/topBar.ejs') %>
    </div>

    <div class="side-bar">
        <%- include('../partials/userSidebar.ejs') %>
    </div>

    <div class="main-content">
        <!-- ================= HERO SECTION ================= -->
        <section class="marketplace-hero">
            <div class="container">
                <h1>TradeNest Marketplace</h1>
                <p>
                    Buy and sell items which you like. Find affordable essentials, gadgets, books, and more from trusted sellers.
                </p>
            </div>
        </section>


        <!-- ================= CATEGORY SECTION ================= -->
        <section class="marketplace-categories">

            <div class="category-header">
                <h2>Browse Categories</h2>
                <p>Find items from different categories in the campus marketplace</p>
            </div>

            <div class="category-grid">
                <% categories.forEach(category => { %>

                    <a class="category-card" href="/user/marketplace/category/<%= category.id %>">
                        <div class="category-icon">
                            <%= category.icon %>
                        </div>

                        <div class="category-text">
                            <h3>
                                <%= category.name.charAt(0).toUpperCase() + category.name.slice(1) %>
                            </h3>
                            <p>Browse listings</p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </section>
    </div>

    <div class="footer">
        <%- include('../partials/footer.ejs') %>
    </div>
</body>
</html>