<%- include('../partials/htmlHead.ejs', {pageCss: "/styles/user/userSales.css"}) %>  


<body>
    <div class="top-bar">
        <%- include('../partials/topBar.ejs') %>
    </div>

    <div class="side-bar">
        <%- include('../partials/userSidebar.ejs') %>
    </div>

    <div class="main-content">

        <!-- ===== NEW PRODUCT ===== -->
        <div class="section">

            <h2>Sell New Product</h2>

            <form class="sell-form" method="POST" action="/user/sell/new">

                <div class="form-grid">

                    <div class="left">
                        <label>Title</label>
                        <input type="text" name="title" required>

                        <label>Description</label>
                        <textarea id="desc" name="description" rows="4" placeholder="Describe the product condition, usage, defects, etc." required></textarea>
                    </div>

                    <div class="right">
                        <label>Category</label>
                        <select name="category_id" required>
                            <option value="">Select category</option>
                            <% categories.forEach(element => { %>
                                <option value="<%= element.id %>"><%= element.name %></option>
                            <% }) %>
                        </select>

                        <label>Price</label>
                        <input type="number" min="1" name="price" required>

                        <label>Quantity</label>
                        <input type="number" min="1" name="quantity_available" required>
                    </div>

                </div>

                <button type="submit" class="post-btn">Post Product</button>

            </form>

        </div>



        <!-- ===== PRODUCT LIST ===== -->
        <div class="section">

            <h2>Your Products</h2>

            <table class="products-table">

                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Available</th>
                        <th>Price</th>
                        <th>Restock</th>
                        <th>Remove</th>
                    </tr>
                </thead>

                <tbody>

                <% products.forEach(element => { %>

                    <tr>
                        <td><%= element.title %></td>
                        <td><%= element.category_name %></td>
                        <td><%= element.status %></td>
                        <td><%= element.quantity_available %></td>
                        <td>₹ <%= element.price %></td>

                        <td>
                            <form method="POST" action="/user/sell/<%= element.id %>/restock">
                                <input type="number" min="0" name="quantity" required>
                                <button type="submit">Add</button>
                            </form>
                        </td>

                        <td>
                            <% if(element.status === 'REMOVED'){ %>

                            <form method="POST" action="/user/sell/<%= element.id %>/relist">
                                <button class="relist-btn" type="submit">Relist</button>
                            </form>

                            <% } else { %>

                            <form method="POST" action="/user/sell/<%= element.id %>/remove">
                                <button class="remove-btn" type="submit">Remove</button>
                            </form>

                            <% } %>
                        </td>

                        
                    </tr>

                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

    <div class="footer">
        <%- include('../partials/footer.ejs') %>
    </div>
</body>
</html>