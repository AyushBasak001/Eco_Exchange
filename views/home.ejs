<%- include('partials/htmlHead.ejs', {pageCss: "/styles/home.css"}) %>

<body>
    <div class="top-bar">
        <%- include('partials/topBar.ejs') %>
    </div>

    <div class="extended-content">

        <div class="home-section home-hero">
            <p class="title">Turning Waste into Worth</p>
            <p class="details">
                Eco-Exchange is a sustainable marketplace where waste materials are transformed into valuable, eco-friendly products.
                Buy responsibly. Sell consciously. Make an impact.
            </p>
        </div>

        <div class="home-section home-working">
            <p class="title">How It Works</p>
            <div class="container">
                <div class="tab">
                    <p class="heading">1. Collect Waste</p>
                    <p class="sub-heading">Plastic, metal, paper, fabric — every waste has value.</p>
                </div>
                <div class="tab">
                    <p class="heading">2. Create Products</p>
                    <p class="sub-heading">Artisans and recyclers convert waste into usable goods.</p>
                </div>
                <div class="tab">
                    <p class="heading">3. Buy & Sell</p>
                    <p class="sub-heading">Users buy sustainable products or sell their creations.</p>
                </div>
            </div>
        </div>

        <div class="home-section home-categories">
            <p class="title">Popular Categories</p>
            <div class="container">
                <p class="tab">Recycled Plastic</p>
                <p class="tab">Upcycled Metal</p>
                <p class="tab">Eco-Furniture</p>
                <p class="tab">Handmade Crafts</p>
            </div>
        </div>

        <div class="home-section home-cta">
            <p class="title">Be a Part of the Green Revolution</p>
            <p class="details">Login to start buying or selling eco-friendly products today.</p>
            <a href="/auth">Login to Continue</a>
        </div>
    </div>

    <div class="footer">
        <%- include('partials/footer.ejs') %>
    </div>
</body>
</html>